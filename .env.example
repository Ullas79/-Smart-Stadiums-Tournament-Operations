# ---- Gemini / Google Gen AI ----
# Use the Gemini Developer API with an API key (simplest for local dev).
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# To use Vertex AI instead, set these and comment out GOOGLE_API_KEY:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ---- Agent Model
GEMINI_MODEL="gemini-2.0-flash"

# LLM Provider (Set to 'ollama' to use local/cloud Ollama)
LLM_PROVIDER="gemini"
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_API_KEY="ollama"
OLLAMA_MODEL="llama3.1"
AGENT_MAX_TOOL_ITERATIONS=6

# ---- Simulator ----
SIM_TICK_SECONDS=5
SIM_SPEED=60

# ---- Server ----
BACKEND_CORS_ORIGINS=http://localhost:5173
